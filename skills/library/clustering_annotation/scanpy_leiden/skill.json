{
  "skill_id": "scanpy_leiden",
  "capability": "clustering_annotation",
  "execution_layer": {
    "required_inputs": [
      "input_data",
      "params_dict"
    ],
    "default_params": {
      "resolution": 1.0,
      "n_neighbors": 15,
      "random_state": 42,
      "key_added": "leiden",
      "directed": false
    },
    "output_objects": [
      "clustered_adata"
    ],
    "script": "run.py"
  },
  "cognitive_layer": {
    "purpose": "Leiden clustering partitions single cells into groups based on transcriptional similarity using community detection on a k-nearest neighbor graph.",
    "parameter_impact": {
      "resolution": "Higher values produce more clusters.",
      "n_neighbors": "More neighbors create smoother, larger clusters."
    }
  },
  "critic_layer": {
    "metrics_to_extract": [
      "n_clusters",
      "cluster_sizes",
      "min_cluster_size",
      "max_cluster_size",
      "mean_cluster_size",
      "fig_path"
    ],
    "success_thresholds": "n_clusters >= 3 and n_clusters <= 200",
    "context_params": [
      "protocol"
    ],
    "script": "critic.py"
  },
  "parameter_science_guide": {
    "resolution": {
      "too_few_clusters": {
        "adjust": "increase resolution by 0.2-0.5",
        "causal_chain": "Higher resolution lowers the similarity threshold for cluster formation"
      },
      "too_many_clusters": {
        "adjust": "decrease resolution by 0.2-0.5",
        "causal_chain": "Lower resolution raises the similarity threshold, merging clusters"
      }
    }
  }
}
